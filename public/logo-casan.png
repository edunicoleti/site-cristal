    <script>
        (function(d,t) {
            var BASE_URL="https://chat.lourens.net.br";
            var g=d.createElement(t),s=d.getElementsByTagName(t)[0];
            g.src=BASE_URL+"/packs/js/sdk.js";
            g.defer = true;
            g.async = true;
            s.parentNode.insertBefore(g,s);
            carregouChat = false;

            window.abreChat = function abreChat() {
                if (carregouChat) {
                    window.$chatwoot.toggle('open');
                } else {
                    window.addEventListener("chatwoot:ready",() => {
                        window.$chatwoot.toggle('open');
                    });
                }
                /*ainda que um link para #chat funcione, chamar esta função no onclick pode ser ideal por:
                - garantir que seja acionado mesmo se já a url no navegador já for #chat, já que o evento de hashchange não dispararia nesse caso
                - evitar que a url do navegador seja alterada para #chat, mantendo a url "limpa" para compartilhamento, SEO, etc.
                */
            }

            g.onload=function(){
                window.chatwootSDK.run({
                    websiteToken: 'WUjKgbt4r6SHFXPs3PiVxHT8',
                    baseUrl: BASE_URL
                });

                window.addEventListener("chatwoot:ready",() => {
                    carregouChat = true;
                    if(window.location.hash === "#chat") {
                        window.$chatwoot.toggle('open');
                    }
                });

                window.addEventListener("hashchange",() => {
                    if(window.location.hash === "#chat") {
                        abreChat();
                    }
                });
            }
        })(document,"script");
    </script>
        
    
